---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---

<a
  class="mx-auto my-6 block w-fit max-w-[20rem] cursor-pointer rounded-full bg-gradient-to-br from-sea-500 to-palm px-12 py-[1.2rem] text-[clamp(1.4rem,3vw,1.75rem)] font-bold text-white no-underline shadow-register transition-[transform,box-shadow,filter] duration-[180ms] ease-[ease] hover:-translate-y-0.5 hover:shadow-register-hover hover:brightness-105 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(14,165,233,0.5)] active:translate-y-px active:shadow-register-active motion-reduce:transition-none"
  href={href}
  rel="noopener noreferrer"
>
  {text}
</a>
