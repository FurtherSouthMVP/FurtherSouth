---
import ImageParagraph from "./ImageParagraph.astro";

interface Props {
  class?: string;
  href: string;
  alt: string;
  width?: number;
  height?: number;
  side?: "left" | "right";
  src: string; // path to logo/image
  text: string;
}

const {
  class: className,
  href,
  alt,
  width = 100,
  height = 100,
  side = "left",
  src,
  text,
} = Astro.props;
---

<a
  href={href}
  class={`relative inline-flex w-1/2 min-w-[15rem] items-center justify-center overflow-hidden rounded-xl border-2 border-transparent bg-none px-6 py-4 text-inherit no-underline shadow-social transition-[transform,box-shadow,border-color,background] duration-[250ms] ease-[ease] before:absolute before:left-[-150%] before:top-0 before:h-full before:w-[200%] before:-skew-x-[20deg] before:bg-[linear-gradient(120deg,transparent,rgba(0,153,255,0.25),transparent)] before:content-[''] before:transition-[left] before:duration-[600ms] before:ease-[ease] hover:-translate-y-1 hover:border-[rgba(0,153,255,0.7)] hover:shadow-social-hover hover:before:left-[150%] ${className || ""}`}
  target="_blank"
  rel="noopener noreferrer"
>
  <ImageParagraph src={src} alt={alt} width={width} height={height} side={side}>
    {text}
  </ImageParagraph>
</a>
