---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import background from "@assets/background.png";
import { Palette, Calendar, Info } from "lucide-astro";
import SpecialButton from "../components/SpecialButton.astro";
---

<Layout title="Further South">
  <section
    class="flex min-h-screen w-full flex-col items-center bg-gradient-to-b from-[#a7f3d0] via-[#60a5fa] to-[#1e3a8a] px-5 pb-12 pt-8"
  >
    <h1
      class="mb-1 inline-block animate-bob whitespace-normal break-words bg-gradient-to-r from-sea-500 to-palm bg-clip-text text-center font-pacifico text-[clamp(1.5rem,8vw,5.5rem)] tracking-[clamp(2px,0.8vw,8px)] text-transparent [text-shadow:0_0_3px_rgba(0,0,0,0.4),0_2px_6px_rgba(0,0,0,0.3)] motion-reduce:animate-none"
    >
      🌊<span class="[-webkit-text-stroke:0.5px_white]">Further South</span>🦊
    </h1>
    <div class="mb-4 mt-8 w-full max-w-[1400px]" aria-hidden="true">
      <Image
        src={background}
        alt="Further South Mascot"
        layout="full-width"
        class="h-auto w-full rounded-[1.25rem] shadow-card"
      />
    </div>

    <div
      class="mt-4 w-full max-w-[1100px] rounded-[1.25rem] border-2 border-[rgba(255,255,255,0.45)] bg-[linear-gradient(135deg,rgba(255,255,255,0.72),rgba(255,255,255,0.55))] p-[clamp(1.5rem,4vw,3rem)] text-center font-quicksand leading-[1.8] text-ink-card shadow-card backdrop-blur-[10px] [-webkit-backdrop-filter:blur(10px)]"
    >
      <p
        class="mx-auto mb-2 mt-2 max-w-[70ch] text-[clamp(1.1rem,2.4vw,1.35rem)] font-semibold"
      >
        <b> Further South </b> is a small, cosy, up-and-coming furry convention;
        celebrating the community, art, and talent within the fandom!
      </p>
      <p class="mx-auto mt-2 max-w-[78ch]">
        Hosted in the heart of Portsmouth, where historic docks meet rolling
        waves and golden sunsets. Join us for our third year running and come
        make it down further south!
      </p>
      <h2
        class="mb-1 mt-4 font-pacifico text-[clamp(1.5rem,3vw,2rem)] font-bold text-sun [text-shadow:0_0_1px_black]"
      >
        March 5th-8th 2027- Holiday Inn, Portsmouth
      </h2>

      <b>
        Registration will open soon for 2027, keep an eye on this space and our
        socials for when it does!
      </b>
      <SpecialButton
        text={"Socials"}
        href={"https://furthersouth.uk/about-us/find-us/"}
      />

      <div
        class="mx-auto mt-8 grid max-w-[800px] grid-cols-[repeat(auto-fit,minmax(180px,1fr))] gap-2 p-0 max-[900px]:grid-cols-1"
        aria-label="Convention highlights"
      >
        <a
          href="/activities/marketplace/"
          class="mx-auto my-1 flex w-fit min-w-[15rem] items-center justify-center gap-2 rounded-full border border-[rgba(255,255,255,0.45)] bg-white/50 px-3 py-2 text-[0.95rem] font-semibold text-ink-card no-underline shadow-highlight transition-[transform,background] duration-150 ease-in-out hover:-translate-y-px hover:bg-white/70 active:translate-y-px"
        >
          <Palette class="h-[18px] w-[18px] text-sea-500" /> Dealers Den & Art Panels
        </a>
        <a
          href="/about-us/join-the-team/"
          class="mx-auto my-1 flex w-fit min-w-[15rem] items-center justify-center gap-2 rounded-full border border-[rgba(255,255,255,0.45)] bg-white/50 px-3 py-2 text-[0.95rem] font-semibold text-ink-card no-underline shadow-highlight transition-[transform,background] duration-150 ease-in-out hover:-translate-y-px hover:bg-white/70 active:translate-y-px"
        >
          <Calendar class="h-[18px] w-[18px] text-sea-500" /> Volunteer as Staff
        </a>
        <a
          href="/about-us/"
          class="mx-auto my-1 flex w-fit min-w-[15rem] items-center justify-center gap-2 rounded-full border border-[rgba(255,255,255,0.45)] bg-white/50 px-3 py-2 text-[0.95rem] font-semibold text-ink-card no-underline shadow-highlight transition-[transform,background] duration-150 ease-in-out hover:-translate-y-px hover:bg-white/70 active:translate-y-px"
        >
          <Info class="h-[18px] w-[18px] text-sea-500" /> About the Convention
        </a>
      </div>
    </div>
  </section>
</Layout>
